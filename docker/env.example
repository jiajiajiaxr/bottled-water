# Copy this file to docker/.env before changing deployment values.

POSTGRES_USER=agenthub
POSTGRES_PASSWORD=agenthub_secret
POSTGRES_DB=agenthub

REDIS_URL=redis://redis:6379/0
AGENTHUB_SECRET_KEY=change-me-before-public-deploy
LOG_LEVEL=INFO

# Host port exposed by nginx.
WEB_PORT=80
PUBLIC_BASE_URL=http://localhost
