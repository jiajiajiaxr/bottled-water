# AgentHub 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# 切勿提交包含真实密钥的 .env 文件！

# ==========================================
# 数据库配置
# ==========================================
# SQLite（本地开发默认）
DATABASE_URL=sqlite:///./agenthub_dev.db

# PostgreSQL（生产环境）
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/agenthub

# ==========================================
# LLM 模型配置
# ==========================================
# 可选值: auto | ark | mock
# auto  = 有 API Key 时自动使用 ark，否则回退到 mock
# ark   = 火山方舟（字节跳动 Volcano Engine）
# mock  = 本地模拟响应，无需真实 API Key
LLM_PROVIDER=auto

# 火山方舟配置（当 LLM_PROVIDER=ark 或 auto 时需要）
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_ENDPOINT_ID=your-endpoint-id-here
ARK_MODEL=doubao-seed-2-0-lite
ARK_API_KEY=your-api-key-here

# ==========================================
# 演示用户（本地开发自动创建）
# ==========================================
DEMO_EMAIL=demo@agenthub.local
DEMO_USERNAME=demo
DEMO_PASSWORD=agenthub

# ==========================================
# 产物与文件存储
# ==========================================
ARTIFACT_BASE_URL=http://localhost:8000
MAX_UPLOAD_MB=50

# ==========================================
# Function Calling（单聊模式流式工具调用）
# ==========================================
# true  = 启用：模型在流式生成中自主决定调用工具（默认）
# false = 禁用：回退到预编排模式（先执行工具再流式生成）
ENABLE_FUNCTION_CALLING=true

# ==========================================
# 应用配置
# ==========================================
# 可选值: development | test | production
ENVIRONMENT=development
