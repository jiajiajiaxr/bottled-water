# 复制此文件为 .env 并填入真实值
# 切勿提交包含真实密钥的 .env 文件！

# ==========================================
# 基础配置
# ==========================================
DATABASE_URL=sqlite:///./agenthub_dev.db
SECRET_KEY=change-me-in-production
API_PORT=8888
FRONTEND_PORT=5173

# ==========================================
# 演示用户（本地开发自动创建）
# ==========================================
DEMO_PASSWORD=agenthub

# ==========================================
# 功能开关
# ==========================================
ENABLE_FUNCTION_CALLING=true

# ==========================================
# 模型配置（可选，已迁移到数据库）
# ==========================================
# 以下配置已弃用，请通过前端"全局设置-模型"页面配置。
# 保留此处仅作为无数据库配置时的 fallback：
# LLM_PROVIDER=auto
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_API_KEY=your-api-key
# ARK_ENDPOINT_ID=your-endpoint-id
