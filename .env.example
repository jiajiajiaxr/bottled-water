# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL=sqlite:///./agenthub_dev.db

# PostgreSQL（生产环境）
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/agenthub

# ==========================================
# LLM 模型配置
# ==========================================
LLM_PROVIDER=auto
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_ENDPOINT_ID=your-endpoint-id
ARK_MODEL=doubao-seed-2-0-lite
ARK_API_KEY=your-api-key-here

# ==========================================
# 演示用户
# ==========================================
DEMO_EMAIL=demo@agenthub.local
DEMO_USERNAME=demo
DEMO_PASSWORD=agenthub

# ==========================================
# 产物与文件存储
# ==========================================
ARTIFACT_BASE_URL=http://localhost:8888
MAX_UPLOAD_MB=50
ENABLE_FUNCTION_CALLING=true

# ==========================================
# 服务监听配置
# ==========================================
API_HOST=0.0.0.0
API_PORT=8888
API_BASE_URL=http://localhost:8888
FRONTEND_PORT=5173

ENVIRONMENT=development